{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2023",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "exclude": ["node_modules"],
  "include": ["src", "scripts", "test"]
}
